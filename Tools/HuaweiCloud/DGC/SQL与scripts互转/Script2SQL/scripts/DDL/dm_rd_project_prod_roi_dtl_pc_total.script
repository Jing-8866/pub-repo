ment '审计线索编码',\n    amount numeric(30,11) comment '本期数',\n    amount_yoy numeric(30,11) comment '同期数'\n)\nWITH (ORIENTATION = column, COMPRESSION = MIDDLE, colversion=3.0, enable_hstore_opt = true) DISTRIBUTE BY Roundrobin\ncomment '数据准备'\n;\n",
